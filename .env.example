# Copy to .env and paste your football-data.org free-tier key.
# Get one at https://www.football-data.org/client/register
FOOTBALL_DATA_AK=your_key_here

# Optional: point the app at the live S3 endpoint (the DataUrl output from the
# AWS SAM stack in infra/). Leave unset to use the bundled/locally-fetched JSON.
# VITE_DATA_URL=https://your-bucket.s3.us-east-1.amazonaws.com/matches.json

# Optional: the two players' display names. Set these to keep real names out of
# committed code (src/config.ts ships generic PLAYER1/PLAYER2 ids). Defaults to
# "Player 1" / "Player 2" if unset.
# VITE_PLAYER1_NAME=Player 1
# VITE_PLAYER2_NAME=Player 2
